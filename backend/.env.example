# Local development
PORT=3000
FRONTEND_URL=http://localhost:5173
MONGODB_URI=mongodb://127.0.0.1:27017/SecondBrain

# Auth
JWT_SECRET=change-this-to-a-long-random-secret
SESSION_EXPIRY=30m

# Google OAuth (from Google Cloud Console)
GOOGLE_CLIENT_ID=

# Demo user (auto-created on server start for presentations)
DEMO_USER_ENABLED=true
DEMO_USER_USERNAME=demo
DEMO_USER_PASSWORD=demo12345

# --- Render / production (set in Render dashboard → Environment) ---
# NODE_ENV=production          (Render sets this automatically)
# PORT=10000                   (Render sets this automatically)
# FRONTEND_URL=https://your-frontend.onrender.com
# MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/SecondBrain?retryWrites=true&w=majority
# JWT_SECRET=use-a-long-random-string-here
# DEMO_USER_ENABLED=false      (recommended for production)
